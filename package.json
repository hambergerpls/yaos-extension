{
	"name": "yaos-extension",
	"version": "1.0.0",
	"description": "Presence indicators and collaborator names for YAOS sync",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint .",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"keywords": [
		"obsidian",
		"yaos",
		"presence",
		"collaboration"
	],
	"license": "0-BSD",
	"devDependencies": {
		"@codemirror/commands": "^6.10.3",
		"@codemirror/state": "^6.6.0",
		"@codemirror/view": "^6.41.0",
		"@eslint/js": "9.30.1",
		"@types/node": "^20.19.39",
		"esbuild": "0.25.5",
		"eslint-plugin-obsidianmd": "0.1.9",
		"globals": "14.0.0",
		"jiti": "2.6.1",
		"jsdom": "^29.0.2",
		"tslib": "2.4.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "8.35.1",
		"vitest": "^4.1.4"
	},
	"dependencies": {
		"obsidian": "latest"
	}
}
